{
  "name": "litetrack-sdk",
  "version": "0.1.0",
  "description": "LiteTrack analytics SDK - lightweight and framework-agnostic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^16.5.0",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "keywords": [
    "analytics",
    "tracking",
    "pageviews",
    "statistics",
    "sdk"
  ],
  "license": "MIT"
}
