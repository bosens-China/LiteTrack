// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  githubId  String   @unique @map("github_id")
  username  String
  avatar    String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sites Site[]

  @@map("users")
}

model Site {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  domain      String
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokens      SiteToken[]
  views       PageView[]
  daily       DailyView[]
  dailyVisitors DailyVisitor[]
  pageDailyVisitors PageDailyVisitor[]
  readProgress PageReadProgress[]
  accessLogs  AccessLog[]

  @@unique([userId, domain])
  @@map("sites")
}

model SiteToken {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  token     String   @unique
  name      String   @default("default")
  description String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("site_tokens")
}

model PageView {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  path      String
  title     String?  // 页面标题
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, path])
  @@map("page_views")
}

model DailyView {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  date      String   // YYYY-MM-DD format
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date])
  @@map("daily_views")
}

// 访问日志 - 记录每次访问的详细信息
model AccessLog {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  path      String   // 访问路径
  title     String?  // 页面标题
  ip        String?  // 访问者 IP
  visitorId String?  @map("visitor_id")
  sessionId String?  @map("session_id")
  userAgent String?  @map("user_agent") // 用户代理
  deviceType String? @map("device_type")
  browser   String?
  os        String?
  referer   String?  // 来源页面
  country   String?  // 国家（通过 IP 解析）
  city      String?  // 城市
  createdAt DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([siteId, path])
  @@map("access_logs")
}

model DailyVisitor {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  date      String   // YYYY-MM-DD format
  visitorId String   @map("visitor_id")
  createdAt DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date, visitorId])
  @@index([siteId, date])
  @@map("daily_visitors")
}

model PageDailyVisitor {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  path      String
  date      String   // YYYY-MM-DD format
  visitorId String   @map("visitor_id")
  createdAt DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, path, date, visitorId])
  @@index([siteId, path, date])
  @@map("page_daily_visitors")
}

model PageReadProgress {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  path      String
  date      String   // YYYY-MM-DD format
  visitorId String   @map("visitor_id")
  maxDepth  Int      @default(0) @map("max_depth")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, path, date, visitorId])
  @@index([siteId, path, date])
  @@map("page_read_progress")
}
